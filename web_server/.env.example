# Copy to .env and set values. For Cloud Run, set these in the service (Variables & Secrets).
# Do not commit .env or real keys.

# --- Required for search / GCS ---
# GCS bucket where pipeline writes job_state/, outputs/, rag_db/, metadata/
GCS_OUTPUT_BUCKET=

# --- Optional: signed URLs (e.g. /api/audio/{job_id}) ---
# On Cloud Run, use Secret Manager and reference as env var GCS_SIGNING_KEY_JSON.
# Locally you can leave unset if using: gcloud auth application-default login
# GCS_SIGNING_KEY_JSON=

# --- RAG (local embeddings and vector DB) ---
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
# Optional: dir where the embedding model is cached (default: rag_db/embedding_model_cache). Reduces re-downloads and avoids HF rate limits.
# RAG_EMBEDDING_CACHE=
# Optional: Hugging Face token for higher rate limits when the model is not yet cached (e.g. first run or Docker build).
# HF_TOKEN=
RAG_SEARCH_LIMIT=20

# --- Server (Cloud Run sets PORT automatically; do not set in Cloud Run) ---
SERVER_HOST=0.0.0.0
# SERVER_PORT=8000
# PORT=8080
